{
  "name": "worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:remote": "wrangler dev --remote",
    "build": "wrangler deploy --dry-run",
    "typecheck": "tsc --noEmit",
    "test": "pnpm exec vitest run",
    "db:generate": "drizzle-kit generate",
    "db:apply:local": "wrangler d1 execute cms-sanity-vite --local --file schema.sql",
    "db:apply:remote": "wrangler d1 execute cms-sanity-vite --remote --file schema.sql",
    "deploy": "wrangler deploy",
    "whoami": "wrangler whoami"
  },
  "dependencies": {
    "@resvg/resvg-wasm": "2.6.2",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.10.5",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260413.1",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.46.0"
  }
}
