{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cms-sanity-vite-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-02",
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["*/15 * * * *"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cms-sanity-vite",
      "database_id": "REPLACE_WITH_D1_DATABASE_ID"
    }
  ]
}
